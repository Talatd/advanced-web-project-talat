# SmartBasket CrewAI Backend
# Environment variables for the CrewAI backend

# OpenAI API Key (required for CrewAI LLM)
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# LangSmith / LangGraph Integration (Tracing & Observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langsmith_api_key_here"
LANGCHAIN_PROJECT="smartbasket-crewai-langgraph"
